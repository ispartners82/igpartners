rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자의 회원 등급을 가져오는 헬퍼 함수
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // users 컬렉션 규칙
    match /users/{userId} {
      // 읽기(read) 규칙: 로그인된 상태이며, 본인 데이터이거나 최고 관리자(super_admin)이거나 또는 해당 등급에 회원리스트 권한(hasPermissions)이 true인 경우 허용합니다
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        getUserRole() == "super_admin" ||
        get(/databases/$(database)/documents/roles/$(getUserRole())).data.hasPermissions == true
      );
      // 쓰기(write) 규칙: 로그인된 상태이며, 본인 데이터이거나 최고 관리자인 경우에만 허용합니다
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        getUserRole() == "super_admin"
      );
    }

    // reservations 컬렉션 규칙
    match /reservations/{reservationId} {
      // 예약 생성은 본인 uid가 맞아야 가능
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      
      // 예약 조회는 본인 소유이거나, 관리자 권한이 있는 경우 가능
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid || 
        getUserRole() in ["admin", "super_admin", "admin_user", "top_manager", "res_manager"]
      );
      
      // 예약 수정/삭제는 관리자 권한이 있는 경우만 가능
      allow update, delete: if request.auth != null && 
        getUserRole() in ["admin", "super_admin", "admin_user", "top_manager", "res_manager"];
    }

    // clinics 컬렉션 규칙
    match /clinics/{clinicId} {
      allow read: if true; // 누구나 조회 가능
      allow write: if request.auth != null && 
        getUserRole() in ["admin", "super_admin", "admin_user", "top_manager", "res_manager"];
    }

    // roles 컬렉션 규칙
    match /roles/{roleId} {
      allow read: if request.auth != null; // 로그인한 회원 누구나 등급 정보 조회 가능
      allow write: if request.auth != null && getUserRole() == "super_admin"; // 최고 관리자만 생성/수정/삭제 가능
    }

    // ads (광고 배너) 컬렉션 규칙
    match /ads/{adId} {
      // 읽기(read) 규칙: 홈페이지 첫 화면에서 누구나(로그인하지 않은 방문자도) 광고판을 볼 수 있도록 전체 공개합니다
      allow read: if true;
      // 쓰기(write) 규칙: 로그인된 상태이며, 지정된 관리자 등급군에 속해 있어야 등록/수정/삭제가 가능하도록 보호합니다
      allow write: if request.auth != null && 
        getUserRole() in ["admin", "super_admin", "admin_user", "top_manager", "res_manager"];
    }
  }
}
